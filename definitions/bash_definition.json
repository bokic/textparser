{
  "name": "bash",
  "version": 1.0,
  "caseSensitivity": true,
  "defaultFileExtensions": ["sh", "bash"],
  "defaultTextEncoding": "latin1",
  "startTokens": [
    "LineComment",
    "Boolean",
    "Keyword",
    "Variable",
    "CodeBlock",
    "Operator",
    "SingleString",
    "DoubleString",
    "Number"
  ],
  "otherTextInside": true,
  "tokens": {
    "LineComment": {
      "type": "SimpleToken",
      "startRegex": "#[^\\r\\n]*",
      "otherTextInside": true
    },
    "Keyword": {
      "type": "SimpleToken",
      "startRegex": "if\\b|then\\b|else\\b|elif\\b|fi\\b|for\\b|while\\b|until\\b|do\\b|done\\b|in\\b|case\\b|esac\\b|select\\b|function\\b|time\\b|local\\b|declare\\b|export\\b|readonly\\b|return\\b|exit\\b|break\\b|continue\\b|alias\\b|unalias\\b|builtin\\b|command\\b|eval\\b|exec\\b|shift\\b|source\\b",
      "textColor": "0xc586c0"
    },
    "Boolean": {
      "type": "SimpleToken",
      "startRegex": "true\\b|false\\b",
      "textColor": "0x088c54"
    },
    "Variable": {
      "type": "SimpleToken",
      "startRegex": "\\$[a-zA-Z_][a-zA-Z0-9_]*|\\$\\{[a-zA-Z_][a-zA-Z0-9_]*\\}|\\$[0-9@?*#$-]|[a-zA-Z_][a-zA-Z0-9_]*(?==)",
      "textColor": "0x9cdcfe"
    },
    "CodeBlock": {
      "type": "StartStop",
      "startRegex": "\\{",
      "endRegex": "\\}",
      "multiLine": true,
      "otherTextInside": true,
      "textColor": "0xffd700",
      "nestedTokens": [
        "LineComment",
        "Boolean",
        "Keyword",
        "Variable",
        "CodeBlock",
        "Operator",
        "SingleString",
        "DoubleString",
        "Number"
      ]
    },
    "Operator": {
      "type": "SimpleToken",
      "startRegex": "&&|\\|\\||>>|<<|==|!=|\\+=|\\-=|[-+*/%&|^~<>!=;.,|]",
      "textColor": "0x35b2dd"
    },
    "SingleString": {
      "type": "StartStop",
      "startRegex": "'",
      "endRegex": "'",
      "multiLine": true,
      "otherTextInside": true,
      "textColor": "0xce9178",
      "nestedTokens": [
        "StringEscape"
      ]
    },
    "DoubleString": {
      "type": "StartStop",
      "startRegex": "\"",
      "endRegex": "\"",
      "multiLine": true,
      "otherTextInside": true,
      "textColor": "0xce9178",
      "nestedTokens": [
        "StringEscape",
        "Variable"
      ]
    },
    "StringEscape": {
      "type": "SimpleToken",
      "startRegex": "\\\\\\\\|\\\\\\\"|\\\\\\'|\\\\n|\\\\r|\\\\t|\\\\\\$",
      "textColor": "0xd7ba7d"
    },
    "Number": {
      "type": "SimpleToken",
      "startRegex": "\\b[0-9]+(?:\\.[0-9]+)?\\b",
      "textColor": "0xb5cea8"
    }
  }
}
