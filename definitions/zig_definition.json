{
  "name": "zig",
  "signAmbiguityFix": true,
  "version": 1.0,
  "caseSensitivity": true,
  "defaultFileExtensions": [
    "zig"
  ],
  "defaultTextEncoding": "utf-8",
  "startTokens": [
    "LineComment",
    "MultiLineString",
    "Directive",
    "Boolean",
    "Keyword",
    "Variable",
    "CodeBlock",
    "Operator",
    "DoubleString",
    "SingleString",
    "Number",
    "Parenthesis",
    "ArrayIndex"
  ],
  "otherTextInside": true,
  "tokens": {
    "LineComment": {
      "type": "SimpleToken",
      "startRegex": "\\/\\/[^\\r\\n]*",
      "otherTextInside": true,
      "textColor": "0x6a9955"
    },
    "MultiLineString": {
      "type": "SimpleToken",
      "startRegex": "\\\\\\\\[^\\r\\n]*",
      "textColor": "0xce9178"
    },
    "Directive": {
      "type": "SimpleToken",
      "startRegex": "@[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "textColor": "0xd7ba7d"
    },
    "Keyword": {
      "type": "SimpleToken",
      "startRegex": "fn\\b|const\\b|var\\b|pub\\b|usingnamespace\\b|align\\b|allowzero\\b|and\\b|anyframe\\b|anytype\\b|asm\\b|async\\b|await\\b|break\\b|cancel\\b|catch\\b|comptime\\b|defer\\b|errdefer\\b|enum\\b|export\\b|extern\\b|for\\b|if\\b|inline\\b|noalias\\b|noinline\\b|nosuspend\\b|or\\b|opaque\\b|packed\\b|resume\\b|return\\b|linksection\\b|struct\\b|suspend\\b|switch\\b|test\\b|threadlocal\\b|try\\b|union\\b|unreachable\\b|volatile\\b|while\\b|orelse\\b|void\\b|noreturn\\b|type\\b|anyerror\\b|bool\\b|f16\\b|f32\\b|f64\\b|f128\\b|c_short\\b|c_ushort\\b|c_int\\b|c_uint\\b|c_long\\b|c_ulong\\b|c_longlong\\b|c_ulonglong\\b|c_longdouble\\b|c_void\\b|isize\\b|usize\\b|i8\\b|u8\\b|i16\\b|u16\\b|i32\\b|u32\\b|i64\\b|u64\\b|i128\\b|u128\\b",
      "textColor": "0xc586c0"
    },
    "Boolean": {
      "type": "SimpleToken",
      "startRegex": "true\\b|false\\b|null\\b|undefined\\b",
      "textColor": "0x088c54"
    },
    "Variable": {
      "type": "SimpleToken",
      "startRegex": "[a-zA-Z_][a-zA-Z0-9_]*",
      "textColor": "0x9cdcfe"
    },
    "CodeBlock": {
      "type": "StartStop",
      "startRegex": "\\{",
      "endRegex": "\\}",
      "multiLine": true,
      "otherTextInside": true,
      "textColor": "0xffd700",
      "nestedTokens": [
        "LineComment",
        "MultiLineString",
        "Directive",
        "Boolean",
        "Keyword",
        "Variable",
        "CodeBlock",
        "Operator",
        "DoubleString",
        "SingleString",
        "Number",
        "Parenthesis",
        "ArrayIndex"
      ]
    },
    "Operator": {
      "type": "SimpleToken",
      "startRegex": "::|:=|:|===|==|!=|<=|>=|&&|\\|\\||\\+=|\\-=|\\*=|\\/=|%=|&=|\\^=|\\|=|<<=|>>=|->|<<|>>|[=<>!&|^~+\\-*/%\\?:;.,]",
      "textColor": "0x35b2dd"
    },
    "DoubleString": {
      "type": "StartStop",
      "startRegex": "\"",
      "endRegex": "\"",
      "multiLine": true,
      "otherTextInside": true,
      "textColor": "0xce9178",
      "nestedTokens": [
        "StringEscape"
      ]
    },
    "SingleString": {
      "type": "StartStop",
      "startRegex": "'",
      "endRegex": "'",
      "multiLine": true,
      "otherTextInside": true,
      "textColor": "0xce9178",
      "nestedTokens": [
        "StringEscape"
      ]
    },
    "StringEscape": {
      "type": "SimpleToken",
      "startRegex": "\\\\\\\\|\\\\\\\"|\\\\\\'|\\\\n|\\\\r|\\\\t|\\\\u[0-9a-fA-F]{4}|\\\\x[0-9a-fA-F]{2}",
      "textColor": "0xd7ba7d"
    },
    "Number": {
      "type": "SimpleToken",
      "startRegex": "0[xX][0-9a-fA-F_]+\\b|0[bB][01_]+\\b|0[oO][0-7_]+\\b|[-+]?[0-9_]*\\.?[0-9_]+(?:[eE][-+]?[0-9_]+)?\\b",
      "textColor": "0xb5cea8"
    },
    "Parenthesis": {
      "type": "StartStop",
      "startRegex": "\\(",
      "endRegex": "\\)",
      "multiLine": true,
      "otherTextInside": true,
      "textColor": "0xffd700",
      "nestedTokens": [
        "LineComment",
        "MultiLineString",
        "Directive",
        "Boolean",
        "Keyword",
        "Variable",
        "CodeBlock",
        "Operator",
        "DoubleString",
        "SingleString",
        "Number",
        "Parenthesis",
        "ArrayIndex"
      ]
    },
    "ArrayIndex": {
      "type": "StartStop",
      "startRegex": "\\[",
      "endRegex": "\\]",
      "multiLine": true,
      "otherTextInside": true,
      "textColor": "0xffd700",
      "nestedTokens": [
        "LineComment",
        "MultiLineString",
        "Directive",
        "Boolean",
        "Keyword",
        "Variable",
        "CodeBlock",
        "Operator",
        "DoubleString",
        "SingleString",
        "Number",
        "Parenthesis",
        "ArrayIndex"
      ]
    }
  }
}
