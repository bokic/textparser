{
  "name": "php",
  "version": 1.0,
  "emptySegmentLanguage": "html",
  "caseSensitivity": true,
  "defaultFileExtensions": ["php", "php5"],
  "defaultTextEncoding": "latin1",
  "startTokens": ["Tag"],
  "otherTextInside": true,
  "tokens": {
    "Tag": {
      "type": "StartOptStop",
      "startRegex": "<\\?php|<\\?",
      "endRegex": "\\?>",
      "multiLine": true,
      "otherTextInside": true,
      "nestedTokens": [
        "LineComment",
        "BlockComment",
        "ArrayKeyValue",
        "MemberAccess",
        "Variable",
        "CodeBlock",
        "Operator",
        "SingleString",
        "DoubleString",
        "Number",
        "Boolean",
        "Keyword"
      ]
    },
    "LineComment": {
      "type": "SimpleToken",
      "startRegex": "\\/\\/[^\\r\\n]*|#[^\\r\\n]*",
      "otherTextInside": true
    },
    "BlockComment": {
      "type": "StartStop",
      "startRegex": "\\/\\*",
      "endRegex": "\\*\\/",
      "multiLine": true,
      "otherTextInside": true
    },
    "ArrayKeyValue": {
      "type": "SimpleToken",
      "startRegex": "=>",
      "textColor": "0x35b2dd"
    },
    "MemberAccess": {
      "type": "SimpleToken",
      "startRegex": "->",
      "textColor": "0x35b2dd"
    },
    "Variable": {
      "type": "SimpleToken",
      "startRegex": "\\$[a-zA-Z_][a-zA-Z0-9_]*",
      "textColor": "0x9cdcfe"
    },
    "CodeBlock": {
      "type": "StartStop",
      "startRegex": "\\{",
      "endRegex": "\\}",
      "multiLine": true,
      "otherTextInside": true,
      "textColor": "0xffd700",
      "nestedTokens": [
        "LineComment",
        "BlockComment",
        "ArrayKeyValue",
        "MemberAccess",
        "Variable",
        "CodeBlock",
        "Operator",
        "SingleString",
        "DoubleString",
        "Number",
        "Boolean",
        "Keyword"
      ]
    },
    "Operator": {
      "type": "SimpleToken",
      "startRegex": "==={0,1}|!=={0,1}|\\+=|\\-=|\\*=|\\/=|\\.\\=|%=|\\+\\+|\\-\\-|<=|>=|==|!=|&&|\\|\\||[=<>!&|^~+\\-*/%\\?:;]",
      "textColor": "0x35b2dd"
    },
    "SingleString": {
      "type": "StartStop",
      "startRegex": "'",
      "endRegex": "'",
      "multiLine": true,
      "otherTextInside": true,
      "textColor": "0xce9178",
      "nestedTokens": [
        "StringEscape"
      ]
    },
    "DoubleString": {
      "type": "StartStop",
      "startRegex": "\"",
      "endRegex": "\"",
      "multiLine": true,
      "otherTextInside": true,
      "textColor": "0xce9178",
      "nestedTokens": [
        "StringEscape",
        "Variable",
        "CodeBlock"
      ]
    },
    "StringEscape": {
      "type": "SimpleToken",
      "startRegex": "\\\\\\\\|\\\\\\\\\\$|\\\\\\\\\\\"|\\\\\\\\\\'|\\\\\\\\n|\\\\\\\\r|\\\\\\\\t",
      "textColor": "0xd7ba7d"
    },
    "Number": {
      "type": "SimpleToken",
      "startRegex": "[-+]?[0-9]+\\.?[0-9]*",
      "textColor": "0xb5cea8"
    },
    "Boolean": {
      "type": "SimpleToken",
      "startRegex": "true\\b|false\\b",
      "textColor": "0x088c54"
    },
    "Keyword": {
      "type": "SimpleToken",
      "startRegex": "echo\\b|print\\b|function\\b|class\\b|public\\b|private\\b|protected\\b|static\\b|if\\b|else\\b|elseif\\b|foreach\\b|for\\b|while\\b|do\\b|switch\\b|case\\b|default\\b|return\\b|require\\b|require_once\\b|include\\b|include_once\\b|new\\b|use\\b|namespace\\b|try\\b|catch\\b|throw\\b|finally\\b|global\\b|as\\b",
      "textColor": "0xc586c0"
    }
  }
}
