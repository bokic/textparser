{
  "name": "fortran",
  "signAmbiguityFix": true,
  "version": 1.0,
  "caseSensitivity": false,
  "defaultFileExtensions": ["f90"],
  "defaultTextEncoding": "latin1",
  "startTokens": [
    "LineComment",
    "Keyword",
    "Boolean",
    "SingleString",
    "DoubleString",
    "Number",
    "Variable",
    "Operator"
  ],
  "otherTextInside": true,
  "tokens": {
    "LineComment": {
      "type": "SimpleToken",
      "startRegex": "![^\\r\\n]*",
      "otherTextInside": true,
      "textColor": "0x6a9955"
    },
    "Keyword": {
      "type": "SimpleToken",
      "startRegex": "abstract\\b|allocatable\\b|allocate\\b|assignment\\b|associated\\b|bind\\b|block\\b|call\\b|case\\b|class\\b|close\\b|common\\b|contains\\b|continue\\b|critical\\b|cycle\\b|data\\b|deallocate\\b|default\\b|deferred\\b|dimension\\b|do\\b|elemental\\b|else\\b|elseif\\b|elsewhere\\b|end\\b|enddo\\b|endif\\b|enum\\b|equivalence\\b|error\\b|exit\\b|extends\\b|external\\b|final\\b|forall\\b|format\\b|function\\b|generic\\b|go\\b|if\\b|implicit\\b|import\\b|in\\b|include\\b|inout\\b|intent\\b|interface\\b|intrinsic\\b|module\\b|new\\b|none\\b|nopass\\b|null\\b|nullify\\b|only\\b|open\\b|operator\\b|optional\\b|out\\b|parameter\\b|pass\\b|pointer\\b|print\\b|private\\b|procedure\\b|program\\b|protected\\b|public\\b|pure\\b|read\\b|recursive\\b|return\\b|save\\b|select\\b|stop\\b|subroutine\\b|target\\b|then\\b|to\\b|type\\b|use\\b|wait\\b|where\\b|while\\b|write\\b",
      "textColor": "0xc586c0"
    },
    "Boolean": {
      "type": "SimpleToken",
      "startRegex": "\\.true\\.|\\.false\\.",
      "textColor": "0x088c54"
    },
    "SingleString": {
      "type": "StartStop",
      "startRegex": "'",
      "endRegex": "'",
      "multiLine": true,
      "otherTextInside": true,
      "searchParentEndTokenLast": true,
      "textColor": "0xce9178",
      "nestedTokens": [
        "EscapedApostrophe"
      ]
    },
    "DoubleString": {
      "type": "StartStop",
      "startRegex": "\"",
      "endRegex": "\"",
      "multiLine": true,
      "otherTextInside": true,
      "searchParentEndTokenLast": true,
      "textColor": "0xce9178",
      "nestedTokens": [
        "EscapedDoubleQuote"
      ]
    },
    "EscapedApostrophe": {
      "type": "SimpleToken",
      "startRegex": "''",
      "textColor": "0xd7ba7d"
    },
    "EscapedDoubleQuote": {
      "type": "SimpleToken",
      "startRegex": "\"\"",
      "textColor": "0xd7ba7d"
    },
    "Number": {
      "type": "SimpleToken",
      "startRegex": "\\b[0-9]+(?:\\.[0-9]+)?(?:[dDeE][-+]?[0-9]+)?\\b|\\.[0-9]+(?:[dDeE][-+]?[0-9]+)?\\b",
      "textColor": "0xb5cea8"
    },
    "Variable": {
      "type": "SimpleToken",
      "startRegex": "[a-zA-Z_][a-zA-Z0-9_]*",
      "textColor": "0x9cdcfe"
    },
    "Operator": {
      "type": "SimpleToken",
      "startRegex": "::|==|\\/=|>=|<=|=>|\\*\\*|\\+|-|\\*|\\/|=|<|>|\\(|\\)|\\[|\\]|,|:|%|;",
      "textColor": "0x35b2dd"
    }
  }
}
